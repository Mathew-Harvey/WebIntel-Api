# =============================================================
# Server
# =============================================================
PORT=3000
NODE_ENV=development
APP_URL=https://api.webintel.dev

# =============================================================
# Database (PostgreSQL) — required for persistent keys & billing
# Without this, keys are stored in-memory from API_KEYS env var
# =============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/webintel

# =============================================================
# API Keys (fallback for local dev without database)
# Format: key:tier (tier defaults to paid)
# =============================================================
API_KEYS=wi_test_abc123:free,wi_live_xyz789:paid

# =============================================================
# Stripe — required for paid subscriptions
# =============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# =============================================================
# Email (Resend) — for welcome emails and magic link login
# Free tier: 100 emails/day at https://resend.com
# =============================================================
RESEND_API_KEY=re_...
FROM_EMAIL=WebIntel <hello@webintel.dev>

# =============================================================
# Auth — JWT secret for magic link tokens and session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================
JWT_SECRET=change-me-generate-a-random-string

# =============================================================
# CORS — comma-separated allowed origins for landing page
# =============================================================
ALLOWED_ORIGINS=https://webintel.dev,https://www.webintel.dev

# =============================================================
# Rate Limits
# =============================================================
FREE_TIER_LIMIT=100
PAID_TIER_LIMIT=5000
RATE_WINDOW_MS=86400000

# =============================================================
# Screenshot settings
# =============================================================
SCREENSHOT_TIMEOUT=15000
MAX_SCREENSHOT_WIDTH=1920
MAX_SCREENSHOT_HEIGHT=1080

# =============================================================
# Preview settings
# =============================================================
PREVIEW_TIMEOUT=10000
MAX_REDIRECT_FOLLOWS=5
MAX_PREVIEW_BODY_BYTES=5242880

# =============================================================
# Web Bot Auth — Ed25519 private key (PKCS#8 PEM) used to sign
# the /.well-known/http-message-signatures-directory response.
# Generate with: openssl genpkey -algorithm ED25519
# If unset, an ephemeral key is generated on boot (dev only).
# =============================================================
# WEB_BOT_AUTH_ED25519_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# =============================================================
# Agent-readiness — canonical URLs used in discovery payloads
# =============================================================
SITE_URL=https://webintel.dev
API_URL=https://api.webintel.dev
